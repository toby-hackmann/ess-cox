@article{andersen1996,
	title = {Estimating the {Survival} {Function} in the {Proportional} {Hazards} {Regression} {Model}: {A} {Study} of the {Small} {Sample} {Size} {Properties}},
	volume = {23},
	issn = {0303-6898},
	shorttitle = {Estimating the {Survival} {Function} in the {Proportional} {Hazards} {Regression} {Model}},
	url = {https://www.jstor.org/stable/4616381},
	abstract = {To study the small sample performance in the proportional hazards regression model of four estimators of the survival function and three procedures for constructing confidence intervals, a Monte Carlo simulation study was conducted. We conclude that even with a sample size of 50 and with 25-50\% censoring it is possible to give reliable estimates of survival probabilities, except perhaps in the extreme right tail of the distribution. The choice of the best estimator is not clearcut though an estimator based on the product integral of Breslow's cumulative hazard estimator tended to have a slightly better overall performance. For the confidence interval a log-log transformation is strongly recommended.},
	number = {1},
	urldate = {2026-02-19},
	journal = {Scandinavian Journal of Statistics},
	publisher = {[Board of the Foundation of the Scandinavian Journal of Statistics, Wiley]},
	author = {Andersen, Per Kragh and Bentzon, Michael Weis and Klein, John P.},
	year = {1996},
	pages = {1--12},
	file = {JSTOR Full Text PDF:C\:\\Users\\thackmann\\Zotero\\storage\\3W3GGWPH\\Andersen et al. - 1996 - Estimating the Survival Function in the Proportional Hazards Regression Model A Study of the Small.pdf:application/pdf},
}

